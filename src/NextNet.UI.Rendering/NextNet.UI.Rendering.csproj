    <PackageTags>nextnet;ui;rendering;theme;component-tree;ssr</PackageTags>
    <PackageId>NextNet.UI.Rendering</PackageId>
    <Version>0.1.0</Version>
    <Authors>NextNet</Authors>
    <Company>NextNet</Company>
    <Product>NextNet</Product>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
