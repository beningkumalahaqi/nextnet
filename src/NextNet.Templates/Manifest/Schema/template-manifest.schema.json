{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nextnet.dev/schemas/template-manifest.json",
  "title": "NextNet Template Manifest",
  "description": "Schema for NextNet template.json manifest files",
  "type": "object",
  "required": ["name", "version", "nextnetVersion"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "nextnetVersion": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "variables": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/variable"
      }
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/feature"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/file"
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/condition"
      }
    }
  },
  "definitions": {
    "variable": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["string", "bool", "number", "enum"],
          "default": "string"
        },
        "default": {},
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "allowedValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "feature": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "file": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "condition": {
          "type": "string"
        },
        "binary": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "condition": {
      "type": "object",
      "required": ["expression"],
      "properties": {
        "expression": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "default": "expression"
        }
      }
    }
  }
}
