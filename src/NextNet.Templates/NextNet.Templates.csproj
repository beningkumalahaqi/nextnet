<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>NextNet.Templates</RootNamespace>
    <AssemblyName>NextNet.Templates</AssemblyName>
    <Description>NextNet Templates - Core data models, interfaces, and abstractions for the NextNet template system</Description>
    <PackageTags>nextnet;templates;scaffolding;codegen;abstractions</PackageTags>
    <PackageId>NextNet.Templates</PackageId>
    <Version>0.1.1</Version>
    <Authors>NextNet</Authors>
    <Company>NextNet</Company>
    <Product>NextNet</Product>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Manifest\Schema\template-manifest.schema.json" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NextNet.Templates.Tests" />
  </ItemGroup>
</Project>
