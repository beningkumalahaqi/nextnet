<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>NextNet.UI.Abstractions</RootNamespace>
    <AssemblyName>NextNet.UI.Abstractions</AssemblyName>
    <Description>NextNet UI Abstractions - Component interfaces, rendering contracts, and theming abstractions</Description>
    <PackageTags>nextnet;ui;abstractions;components;rendering;theme</PackageTags>
    <PackageId>NextNet.UI.Abstractions</PackageId>
    <Version>0.1.0</Version>
    <Authors>NextNet</Authors>
    <Company>NextNet</Company>
    <Product>NextNet</Product>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/beningkumalahaqi/nextnet</PackageProjectUrl>
    <RepositoryUrl>https://github.com/beningkumalahaqi/nextnet.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NextNet.DesignSystem\NextNet.DesignSystem.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.*" />
    <PackageReference Include="Microsoft.AspNetCore.Html.Abstractions" Version="2.2.*" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NextNet.UI.Abstractions.Tests" />
  </ItemGroup>

</Project>
