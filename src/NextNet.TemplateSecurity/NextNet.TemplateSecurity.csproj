<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>NextNet.TemplateSecurity</RootNamespace>
    <AssemblyName>NextNet.TemplateSecurity</AssemblyName>
    <Description>NextNet Template Security - Checksum verification, signature verification, trusted publisher registry, and key management</Description>
    <PackageTags>nextnet;templates;security;checksum;signature;publisher</PackageTags>
    <PackageId>NextNet.TemplateSecurity</PackageId>
    <Version>0.2.0</Version>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Authors>NextNet</Authors>
    <Company>NextNet</Company>
    <Product>NextNet</Product>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\NextNet.Templates\NextNet.Templates.csproj" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="NextNet.TemplateSecurity.Tests" />
  </ItemGroup>
</Project>
